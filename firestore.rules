rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return isSignedIn() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    function isOrganizer() {
      return isSignedIn() && userRole() == 'organizer';
    }

    function organizerMirrorCreateAllowed() {
      return isOrganizer()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.isFeatured == false
        && request.resource.data.featureStatus in ['none', 'pending']
        && request.resource.data.featuredRank == null;
    }

    function organizerMirrorUpdateAllowed() {
      return isOrganizer()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.isFeatured == false
        && request.resource.data.featureStatus in ['none', 'pending']
        && request.resource.data.featuredRank == null;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /supplierProfiles/{profileId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /organizerProfiles/{profileId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /organizers/{uid}/manage/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /organizers/{uid}/events/{eventId} {
      allow read, write: if isOwner(uid);

      match /guests/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /scanOutcomes/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /planner/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /registration/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /onsite/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /audit/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /staff/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /incidents/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /waitlist/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /checkins/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    match /marketplaceEvents/{eventId} {
      allow read: if true;
      allow create: if isAdmin() || organizerMirrorCreateAllowed();
      allow update: if isAdmin() || organizerMirrorUpdateAllowed();
      allow delete: if isAdmin() || (isOrganizer() && resource.data.ownerUid == request.auth.uid);
    }
  }
}
