# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your apps → SDK setup and configuration

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_APPCHECK_SITE_KEY=
# Optional for local/dev only: set to "true" or a specific debug token.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Optional: force all services to local mode (skip Firebase initialization).
VITE_FORCE_LOCAL_SERVICES=false

# Optional: enable local auth fallback when Firebase is unavailable.
# Defaults: true in dev/test, false in production builds.
VITE_ENABLE_LOCAL_AUTH_FALLBACK=false

# PayMongo (for payments)
VITE_PAYMONGO_PUBLIC_KEY=
